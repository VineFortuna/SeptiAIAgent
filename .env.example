# Flask
PORT=5000

# OpenAI
# Required for pricing, discounts, lichess onboarding, tournaments, and the
# lead-intake conversation to work. Without it, the bot can only handle
# greetings/thanks/staff-handoff/help and the original generic class FAQs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Twilio security
# For the very first local test, leave this false.
# Change it to true when TWILIO_AUTH_TOKEN and PUBLIC_BASE_URL are configured.
VALIDATE_TWILIO_SIGNATURE=false
TWILIO_AUTH_TOKEN=
PUBLIC_BASE_URL=

# Twilio outbound staff notification
# Sent whenever a lead finishes the intake questions, so Septi knows to
# follow up. TWILIO_ACCOUNT_SID/AUTH_TOKEN are from the Twilio console.
# TWILIO_WHATSAPP_FROM is Twilio's WhatsApp sender, e.g. whatsapp:+14155238886
# STAFF_NOTIFICATION_PHONE is Septi's WhatsApp number, e.g. whatsapp:+407XXXXXXXX
TWILIO_ACCOUNT_SID=
TWILIO_WHATSAPP_FROM=
STAFF_NOTIFICATION_PHONE=

# Business hours
# The bot only replies live 7am-9pm Eastern; outside that it queues messages
# silently by design. Set this to true temporarily for local demos/testing so
# you get an immediate reply regardless of the real time. Leave false for
# real customers.
DISABLE_BUSINESS_HOURS=false
